# Identificador do dispositivo ESP32 monitorado (default: esp32-001)
VITE_DEVICE_ID=esp32-001

# URL base da API REST. Em desenvolvimento, deixe vazio para usar o proxy do Vite
# (configurado em vite.config.ts apontando para o backend local).
VITE_API_URL=

# URL do WebSocket. Em desenvolvimento, deixe vazio para usar o proxy do Vite.
# Em produção, aponte para o backend, ex.: wss://api.seu-dominio.com
VITE_WS_URL=
